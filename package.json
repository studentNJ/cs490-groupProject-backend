  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "check": "node --check index.js",
    "test": "npm run test:unit",
    "test:unit": "node --test tests/*.test.js",
    "test:db:create": "NODE_ENV=test npx sequelize-cli db:create",
    "test:db:migrate": "NODE_ENV=test npx sequelize-cli db:migrate",
    "test:db:reset": "NODE_ENV=test npx sequelize-cli db:drop && NODE_ENV=test npx sequelize-cli db:create && NODE_ENV=test npx sequelize-cli db:migrate",
    "test:integration": "NODE_ENV=test node --test --test-concurrency=1 tests/integration/*.test.js"
  },
